{
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [],
    "filesystem": {
      "allowRead": [],
      "denyRead": [".env*"],
      "allowWrite": ["."],
      "denyWrite": [".claude/"]
    },
    "network": {
      "allowedDomains": ["api.anthropic.com"],
      "deniedDomains": []
    }
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Read(.env*)",
      "Read(.claude/settings*)",
      "Edit(.claude/settings*)",
      "Write(.claude/settings*)",
      "WebFetch(*)"
    ]
  }
}
